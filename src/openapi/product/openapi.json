          "minimumOrderQuantity": { "type": "number" },
          "meta": {
            "type": "object",
            "properties": {
              "createdAt": { "type": "string" },
              "updatedAt": { "type": "string" },
              "barcode": { "type": "string" },
              "qrCode": { "type": "string" }
